# Docs site — environment variables.
# Copy to `.env.local` (gitignored) and adjust.

# ── AI search (used by src/app/api/chat/route.ts) ─────────────────────────
# OpenRouter API key. Get one at https://openrouter.ai/keys.
# Without this, the AI-search panel in the docs will return errors.
OPENROUTER_API_KEY=

# Model identifier to use. Defaults to anthropic/claude-sonnet-4-6 (best tier for
# RAG-grounded doc Q&A). Use anthropic/claude-opus-4-8 for the most capable model.
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# ── Client-side (NEXT_PUBLIC_*) ───────────────────────────────────────────
# Public docs URL — used for canonical tags and sitemaps.
NEXT_PUBLIC_DOCS_URL=http://localhost:3003

# Optional: link back to the marketing site / admin from the docs nav.
# NEXT_PUBLIC_WEB_URL=http://localhost:3001
# NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
