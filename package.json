{
  "name": "qeet-docs",
  "version": "0.1.0",
  "private": true,
  "description": "Qeet docs platform — all product documentation under docs.qeet.in (/id, /people, /logs, …)",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs,.cjs",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,css,html,mdx,yml,yaml}\"",
    "check": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs,.cjs && prettier --check \"**/*.{js,jsx,ts,tsx,mjs,cjs,json,jsonc,css,html,mdx,yml,yaml}\"",
    "typecheck": "fumadocs-mdx && next typegen && tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.196",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@qeetrix/brand": "^0.0.1",
    "@qeetrix/ui": "^0.1.0",
    "@radix-ui/react-presence": "^1.1.5",
    "@thesvg/react": "^3.0.7",
    "ai": "^6.0.194",
    "class-variance-authority": "^0.7.1",
    "flexsearch": "^0.8.212",
    "fumadocs-core": "16.9.3",
    "fumadocs-mdx": "15.0.10",
    "fumadocs-ui": "16.9.3",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "lenis": "^1.3.23",
    "lucide-react": "^1.17.0",
    "motion": "^12.40.0",
    "next": "16.2.6",
    "ogl": "^1.0.11",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "tailwind-merge": "^3.6.0",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@qeetrix/eslint-config": "^0.0.1",
    "@qeetrix/tsconfig": "^0.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/hast": "^3.0.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "sharp",
      "unrs-resolver"
    ]
  }
}
